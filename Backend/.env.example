PORT=5000
MONGODB_URI=mongodb://<db_username>:<db_password>@<host-1>:27017,<host-2>:27017,<host-3>:27017/<database>?ssl=true&replicaSet=<replica-set>&authSource=admin&appName=<app-name>
DEFAULT_USER_PASSWORD=ChangeMe123!
MAIL_USERNAME=example@gmail.com
MAIL_PASSWORD=your_16_character_gmail_app_password
MAIL_FROM=UniGuide AI <example@gmail.com>
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Gemini generation and embeddings
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_TIMEOUT_MS=45000

# Add as many rotated keys as you have available.
GEMINI_API_KEY_1=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=
GEMINI_API_KEY_5=
GEMINI_API_KEY_6=
GEMINI_API_KEY_7=
GEMINI_API_KEY_8=
GEMINI_API_KEY_9=
